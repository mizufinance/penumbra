# exclude everything by default from container images,
# re-add directories explicitly.
**/
!crates/
!assets/
!Cargo.toml
!Cargo.lock
!.cargo/
!rust-toolchain.toml
!web/
!web/packages/
!web/packages/wasm/
!web/packages/wasm/crate/
!web/packages/wasm/crate/Cargo.toml
!web/packages/wasm/crate/src/
!web/packages/wasm/crate/src/lib.rs

# localnet for 'pd testnet generate' defaults
!deployments/000-localnet/
!deployments/audit-demo/
# cometbft config template and CI validators
!testnets/
# metrics containers
!deployments/config/
# relayer container
!deployments/relayer/
# summonerd tool, for orchestrating contributions
!tools/summonerd/
# parameter setup tool, for wrangling circuit configuration
!tools/parameter-setup/
# gnark circuit metadata and proving/verifying keys required by proof-params
!tools/gnark/
!tools/gnark/**
!tools/gnark/artifacts/
!tools/gnark/artifacts/**
!tools/gnark/internal/
!tools/gnark/internal/generated/
!tools/gnark/internal/generated/**
!tools/gnark/transfer_families.json
tools/gnark/rust-vectors/target/
tools/gnark/rust-vectors/target/**
# picturesque setup tool, for wrangling node configs
!tools/picturesque/

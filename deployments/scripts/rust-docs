#!/usr/bin/env bash
# Rebuild Rust crate documentation.
#
# We use a custom build process for the Rust API docs, in order to provide
# a landing page that lists all relevant crates on a single page.
set -euo pipefail

# Set:
# --enable-index-page -Zunstable-options
#     to generate the index page
# --cfg docsrs
#     to enable nightly-only doc_cfg annotations
export RUSTDOCFLAGS="--enable-index-page -Zunstable-options --cfg docsrs"

# Explicitly specify which crates should be included.
# Guidelines:
# - workspace crates are included
# - git dependencies are included
# - published crates are excluded
# Doing this in one go is useful because the JSON file with search
# indexes is overwritten on each cargo doc invocation.

package_specs_file="$(mktemp)"
trap 'rm -f "$package_specs_file"' EXIT
python3 > "$package_specs_file" <<'PY'
import json
import subprocess
from pathlib import Path

try:
    import tomllib
except ModuleNotFoundError:
    tomllib = None


def git_packages_from_lock(lock_text):
    if tomllib is not None:
        lock = tomllib.loads(lock_text)
        for pkg in lock.get("package", []):
            source = pkg.get("source")
            if source and source.startswith("git+"):
                yield f"{pkg['name']}@{pkg['version']}"
        return

    current = {}
    for line in [*lock_text.splitlines(), "[[package]]"]:
        line = line.strip()
        if line == "[[package]]":
            source = current.get("source")
            if source and source.startswith("git+"):
                yield f"{current['name']}@{current['version']}"
            current = {}
            continue
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        value = value.strip()
        if key in {"name", "version", "source"} and value.startswith('"') and value.endswith('"'):
            current[key] = value[1:-1]


meta = json.loads(
    subprocess.check_output(
        ["cargo", "metadata", "--format-version=1", "--no-deps"],
        text=True,
    )
)

workspace = []
for pkg in meta["packages"]:
    if any(target.get("doc", False) for target in pkg.get("targets", [])):
        workspace.append(pkg["name"])

git_packages = list(git_packages_from_lock(Path("Cargo.lock").read_text()))

for spec in sorted(dict.fromkeys(workspace)):
    print(spec)

for spec in sorted(dict.fromkeys(git_packages)):
    print(spec)
PY

package_specs=()
while IFS= read -r spec; do
  package_specs+=("$spec")
done < "$package_specs_file"

cargo_args=()
for spec in "${package_specs[@]}"; do
  cargo_args+=(-p "$spec")
done

# The nix version of `cargo` does not support the `+nightly` flag.
# There's a nix devShell specifically for nightly Rust, that's used in CI.
# We'll still support non-nix Rust nightlies, though.
nightly_opt=""
if [[ -z "${IN_NIX_SHELL:-}" ]] ; then
  nightly_opt="+nightly"
fi
cargo $nightly_opt doc --no-deps "${cargo_args[@]}"

>&2 echo "Copying newly built index file to docroot for deployment"
cp -v target/doc/index.html docs/rustdoc/index.html
